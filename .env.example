# ─── OID Tree ────────────────────────────────────────────────────────────────
# The root OID this instance manages. Must be a valid dotted-integer OID.
# Example: 2.16.840.1.113762  (NIH / VSAC root)
ROOT_OID=2.16.840.1.113762

# ─── Admin Authentication ────────────────────────────────────────────────────
# Secret key required in X-Admin-Key header for all write operations.
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=change-me-generate-with-openssl-rand-hex-32

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=oid_universe
POSTGRES_USER=oid_app
POSTGRES_PASSWORD=change-me

# Constructed from the above — used by the API service.
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db/${POSTGRES_DB}

# ─── Next.js / NextAuth ──────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-hex-32
NEXTAUTH_URL=http://localhost:3000

# Backend URL as seen by the Next.js container (internal Docker network)
API_URL=http://api:8000

# ─── Ports ───────────────────────────────────────────────────────────────────
API_PORT=8000
WEB_PORT=3000
