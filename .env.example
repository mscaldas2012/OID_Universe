# =============================================================================
# OID Universe — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in real values before running the stack.
#
#   cp .env.example .env
#
# SECURITY: Never commit your .env file. It is listed in .gitignore.
#            This .env.example file contains only safe placeholder values
#            and is safe to commit.
# =============================================================================


# ─── OID Tree ────────────────────────────────────────────────────────────────
#
# ROOT_OID
#   The root OID arc that this instance manages. Every OID stored in the
#   database must be a descendant of (or equal to) this value. The API
#   enforces this at write time; incorrect values will cause all POST/PUT
#   requests to be rejected with HTTP 422.
#
#   Format : Dotted-integer notation — one or more non-negative integers
#             separated by dots. No leading zeros, no trailing dot.
#             Examples:
#               2.16.840.1.113762   (NIH / VSAC root)
#               1.2.840.10008       (DICOM root)
#               2.5.4               (X.500 attribute types)
#
#   Missing : The API container will refuse to start (startup validation).
#
ROOT_OID=2.16.840.1.113762


# ─── Admin Authentication ────────────────────────────────────────────────────
#
# ADMIN_API_KEY
#   Shared secret that authorizes write operations (POST, PUT, DELETE) on the
#   backend API. Callers must supply it as the HTTP request header:
#
#       X-Admin-Key: <value>
#
#   The frontend admin panel reads this from the server-side session and
#   attaches it automatically — it is never exposed to the browser.
#
#   Generate  : openssl rand -hex 32
#   Format    : Any printable ASCII string; minimum 32 characters recommended.
#   Security  : Never commit the real value. Rotate by updating this variable
#               and restarting the api and web containers. Treat it like a
#               database password — store it in a secrets manager in
#               production (e.g. AWS Secrets Manager, Vault, Doppler).
#   Missing   : All write endpoints return HTTP 401; the admin UI cannot log in.
#
ADMIN_API_KEY=change-me-generate-with-openssl-rand-hex-32


# ─── Database ────────────────────────────────────────────────────────────────
#
# POSTGRES_DB
#   Name of the PostgreSQL database created by the db container on first start.
#   Alembic migrations and the API both connect to this database.
#
#   Format  : Alphanumeric and underscores; no spaces.
#   Default : oid_universe
#   Missing : The db container will create a database named "postgres" instead,
#             causing the API to fail to connect.
#
POSTGRES_DB=oid_universe

# POSTGRES_USER
#   Username the API service uses to connect to PostgreSQL. Created
#   automatically by the db container on first start.
#
#   Format  : Alphanumeric and underscores; no spaces.
#   Default : oid_app
#   Security: Use a dedicated least-privilege user (not "postgres").
#   Missing : The API cannot authenticate to the database → HTTP 500 on all
#             endpoints.
#
POSTGRES_USER=oid_app

# POSTGRES_PASSWORD
#   Password for POSTGRES_USER. Used by both the db container (to create the
#   user) and the API container (to connect).
#
#   Generate  : openssl rand -hex 24
#   Format    : Any printable ASCII string without the '@' or '/' characters
#               (those break the connection URL). Minimum 16 characters.
#   Security  : Never commit the real value. Change it before deploying to any
#               shared or public environment.
#   Missing   : The API cannot authenticate to the database → HTTP 500 on all
#               endpoints.
#
POSTGRES_PASSWORD=change-me

# DATABASE_URL
#   Full SQLAlchemy async connection URL used by the API service. Constructed
#   from the three variables above. In most setups you do not need to change
#   this directly — update the components instead.
#
#   Format  : postgresql+asyncpg://<user>:<password>@<host>/<dbname>
#             The host "db" refers to the Docker Compose service name. Change
#             to "localhost" (or a real hostname) for non-Docker deployments.
#   Missing : The API will raise a startup error and exit immediately.
#
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db/${POSTGRES_DB}


# ─── Next.js / NextAuth ──────────────────────────────────────────────────────
#
# NEXTAUTH_SECRET
#   Secret used by NextAuth v5 to sign and encrypt session tokens (JWTs) and
#   CSRF cookies. If this value changes, all existing sessions are immediately
#   invalidated — users will be logged out.
#
#   Generate  : openssl rand -hex 32
#   Format    : Any string; minimum 32 characters. Hex output from openssl is
#               recommended (64 printable ASCII characters).
#   Security  : Never commit the real value. Do not reuse the same secret
#               across environments (dev / staging / production).
#   Missing   : NextAuth will throw a configuration error and the web
#               container will fail to start.
#
NEXTAUTH_SECRET=change-me-generate-with-openssl-rand-hex-32

# NEXTAUTH_URL
#   The canonical public URL of the web application. NextAuth uses this for
#   callback URLs, CSRF verification, and redirect targets.
#
#   Format    : Full URL including scheme, host, and (if non-standard) port.
#               No trailing slash.
#               Local dev  : http://localhost:3000
#               Production : https://oids.example.com
#   Missing   : OAuth callbacks and post-login redirects will break. The admin
#               login page may redirect to an incorrect URL.
#
NEXTAUTH_URL=http://localhost:3000

# API_URL
#   URL the Next.js container (server side) uses to reach the FastAPI backend.
#   This is an internal Docker network address — it is never sent to the
#   browser.
#
#   Format    : http://<docker-service-name>:<port>  (Docker Compose)
#               Use http://localhost:8000 for non-Docker / local dev where
#               both services run directly on the host.
#   Missing   : All server-side data fetching in Next.js will fail with a
#               connection error → pages render empty or return HTTP 500.
#
API_URL=http://api:8000


# ─── Rate Limiting ───────────────────────────────────────────────────────────
#
# PUBLIC_RATE_LIMIT
#   Maximum number of requests per minute allowed from a single IP address on
#   public read endpoints:
#       GET /oid/*
#       GET /search
#
#   The limit is enforced by the API using a sliding-window counter stored in
#   memory (per-process). Requests exceeding the limit receive HTTP 429.
#
#   Format    : Positive integer.
#   Default   : 60  (one request per second on average)
#   Guidance  : Increase for trusted internal deployments or high-traffic
#               scenarios. Decrease for publicly exposed instances with
#               abuse concerns. Set to 0 to disable rate limiting entirely
#               (not recommended for public-facing deployments).
#   Missing   : The API falls back to the default of 60.
#
PUBLIC_RATE_LIMIT=60


# ─── Ports ───────────────────────────────────────────────────────────────────
#
# API_PORT
#   Host port mapped to the FastAPI container. The Uvicorn server inside the
#   container always listens on 8000; this variable controls which port Docker
#   exposes on the host machine.
#
#   Format  : Integer 1024–65535. Avoid privileged ports (<1024) unless
#             running as root or with CAP_NET_BIND_SERVICE.
#   Default : 8000
#   Missing : Docker Compose will not expose the API port to the host (the
#             internal network still works; the web container is unaffected).
#
API_PORT=8000

# WEB_PORT
#   Host port mapped to the Next.js container.
#
#   Format  : Integer 1024–65535.
#   Default : 3000
#   Missing : The web UI will not be reachable from the host browser, but
#             the container still runs on the internal Docker network.
#
WEB_PORT=3000
